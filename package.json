{
  "name": "proxiero",
  "description": "One-click proxy switching extension for Chrome, Firefox and Zen Browser",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "author": "Alex Repin <alxrepin@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alxrepin/proxiero.git"
  },
  "homepage": "https://github.com/alxrepin/proxiero#readme",
  "bugs": {
    "url": "https://github.com/alxrepin/proxiero/issues"
  },
  "keywords": [
    "browser-extension",
    "proxy",
    "chrome",
    "firefox",
    "wxt",
    "svelte"
  ],
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:zen": "ZEN=1 wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "icons": "node scripts/gen-icons.mjs",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@vitest/coverage-v8": "^3.2.7",
    "@wxt-dev/module-svelte": "^2.0.5",
    "jsdom": "^25.0.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.3",
    "vitest": "^3.2.7",
    "wxt": "^0.20.27"
  }
}
